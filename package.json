{
  "name": "@nanoprym/core",
  "version": "0.1.0",
  "description": "Self-evolving AI agent orchestration system",
  "main": "dist/core/orchestrator.js",
  "types": "dist/core/orchestrator.d.ts",
  "bin": {
    "nanoprym": "./dist/cli/cli.entry.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/core/orchestrator.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "tom:start": "python3 src/tom/tom.sidecar.py",
    "tom:test": "python3 -m pytest src/tom/tests/",
    "dashboard": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "dashboard:install": "cd dashboard && npm install",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "self-evolving",
    "claude"
  ],
  "author": "Akshay Nikhare",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "bullmq": "^5.0.0",
    "commander": "^12.0.0",
    "eventemitter3": "^5.0.1",
    "ioredis": "^5.4.0",
    "js-yaml": "^4.1.0",
    "sql.js": "^1.11.0",
    "tiktoken": "^1.0.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.ts": "eslint --no-warn-ignored --fix"
  }
}
