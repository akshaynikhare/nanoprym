# Nanoprym Environment Variables

# Slack Bot (Bolt.js Socket Mode — interactive approval workflows)
# Create a Slack app at https://api.slack.com/apps with Socket Mode enabled
# Required scopes: chat:write, channels:read
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...

# Legacy webhook (one-way notifications, no interactive features)
# SLACK_WEBHOOK_URL=your-slack-webhook-url-here
